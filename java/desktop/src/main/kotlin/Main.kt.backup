import androidx.compose.desktop.ui.tooling.preview.Preview
import androidx.compose.foundation.layout.*
import androidx.compose.foundation.rememberScrollState
import androidx.compose.foundation.verticalScroll
import androidx.compose.material.icons.Icons
import androidx.compose.material.icons.filled.*
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Alignment
import androidx.compose.ui.Modifier
import androidx.compose.ui.unit.dp
import androidx.compose.ui.window.*
import com.termintracker.components.*
import com.termintracker.database.DatabaseManager
import com.termintracker.localization.Translations
import com.termintracker.model.*
import com.termintracker.viewmodel.AppointmentViewModel
import kotlinx.coroutines.*
import kotlinx.datetime.*
import java.io.File
import javax.swing.JFileChooser
import javax.swing.filechooser.FileNameExtensionFilter
import kotlin.system.exitProcess

fun main() = application {
    // Initialize database
    DatabaseManager.initialize()
    
    // Initialize ViewModel
    val viewModel = remember { AppointmentViewModel() }
    
    // Set language from preferences
    LaunchedEffect(Unit) {
        val lang = viewModel.personalInfo.value.preferredLanguage
        Translations.setLanguage(lang)
    }
    
    Window(
        onCloseRequest = {
            viewModel.dispose()
            DatabaseManager.close()
            exitApplication()
        },
        title = "Termin Tracker v1.0.2",
        resizable = true,
        state = rememberWindowState(width = 1200.dp, height = 800.dp)
    ) {
        MaterialTheme {
            Surface {
                TerminTrackerApp(viewModel)
            }
        }
    }
}

@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun TerminTrackerApp(viewModel: AppointmentViewModel) {
    val appointments by viewModel.appointments.collectAsState()
    val isLoading by viewModel.isLoading.collectAsState()
    val notificationMessage by viewModel.notificationMessage.collectAsState()
    val personalInfo by viewModel.personalInfo.collectAsState()
    val searchResults by viewModel.searchResults.collectAsState()
    
    var currentScreen by remember { mutableStateOf(Screen.Appointments) }
    var showAddAppointment by remember { mutableStateOf(false) }
    var selectedAppointment by remember { mutableStateOf<Appointment?>(null) }
    
    // Notification handling
    LaunchedEffect(notificationMessage) {
        notificationMessage?.let {
            // Auto-clear after showing
        }
    }
    
    Scaffold(
        topBar = {
            TopAppBar(
                title = { Text(Translations.appTitle() + " v1.0.2") },
                colors = TopAppBarDefaults.topAppBarColors(
                    containerColor = MaterialTheme.colorScheme.primaryContainer,
                    titleContentColor = MaterialTheme.colorScheme.primary
                ),
                actions = {
                    // Language selector
                    var langExpanded by remember { mutableStateOf(false) }
                    Box {
                        IconButton(onClick = { langExpanded = true }) {
                            Text(
                                when (personalInfo.preferredLanguage) {
                                    Language.GERMAN -> "DE"
                                    Language.ENGLISH -> "EN"
                                    Language.TURKISH -> "TR"
                                },
                                style = MaterialTheme.typography.labelLarge
                            )
                        }
                        DropdownMenu(
                            expanded = langExpanded,
                            onDismissRequest = { langExpanded = false }
                        ) {
                            Language.entries.forEach { lang ->
                                DropdownMenuItem(
                                    text = { Text(lang.displayName) },
                                    onClick = {
                                        viewModel.setLanguage(lang)
                                        langExpanded = false
                                    }
                                )
                            }
                        }
                    }
                    
                    // Settings button
                    IconButton(onClick = { currentScreen = Screen.Settings }) {
                        Icon(Icons.Default.Settings, contentDescription = Translations.settings())
                    }
                }
            )
        },
        floatingActionButton = {
            if (currentScreen == Screen.Appointments) {
                FloatingActionButton(
                    onClick = { showAddAppointment = true }
                ) {
                    Icon(Icons.Default.Add, contentDescription = Translations.newAppointment())
                }
            }
        },
        bottomBar = {
            NavigationBar {
                NavigationBarItem(
                    icon = { Icon(Icons.Default.CalendarToday, null) },
                    label = { Text(Translations.appointments()) },
                    selected = currentScreen == Screen.Appointments,
                    onClick = { currentScreen = Screen.Appointments }
                )
                NavigationBarItem(
                    icon = { Icon(Icons.Default.Person, null) },
                    label = { Text(Translations.personalInfo()) },
                    selected = currentScreen == Screen.PersonalInfo,
                    onClick = { currentScreen = Screen.PersonalInfo }
                )
                NavigationBarItem(
                    icon = { Icon(Icons.Filled.Settings, null) },
                    label = { Text(Translations.settings()) },
                    selected = currentScreen == Screen.Settings,
                    onClick = { currentScreen = Screen.Settings }
                )
            }
        }
    ) { paddingValues ->
        Box(
            modifier = Modifier
                .fillMaxSize()
                .padding(paddingValues)
        ) {
            when (currentScreen) {
                Screen.Appointments -> AppointmentsScreen(
                    appointments = appointments,
                    viewModel = viewModel,
                    onEditAppointment = { appointment ->
                        selectedAppointment = appointment
                        showAddAppointment = true
                    }
                )
                Screen.PersonalInfo -> PersonalInfoScreen(
                    personalInfo = personalInfo,
                    onSave = { viewModel.savePersonalInfo(it) }
                )
                Screen.Settings -> SettingsScreen(viewModel = viewModel)
            }
            
            if (isLoading) {
                CircularProgressIndicator(
                    modifier = Modifier.align(Alignment.Center)
                )
            }
            
            // Snackbar for notifications
            notificationMessage?.let { message ->
                Snackbar(
                    modifier = Modifier.align(Alignment.BottomCenter).padding(16.dp),
                    action = {
                        TextButton(onClick = { viewModel.clearNotification() }) {
                            Text("Dismiss")
                        }
                    }
                ) {
                    Text(message)
                }
            }
        }
    }
    
    // Add/Edit Appointment Dialog
    if (showAddAppointment) {
        AppointmentDialog(
            appointment = selectedAppointment,
            viewModel = viewModel,
            onDismiss = {
                showAddAppointment = false
                selectedAppointment = null
            },
            onSave = { appointment ->
                if (selectedAppointment != null) {
                    viewModel.updateAppointment(appointment)
                } else {
                    viewModel.addAppointment(appointment)
                }
                showAddAppointment = false
                selectedAppointment = null
            }
        )
    }
}

@Composable
fun AppointmentsScreen(
    appointments: List<Appointment>,
    viewModel: AppointmentViewModel,
    onEditAppointment: (Appointment) -> Unit
) {
    var selectedTab by remember { mutableStateOf(0) }
    val tabs = listOf(Translations.upcoming(), Translations.today(), Translations.past())
    
    Column(modifier = Modifier.fillMaxSize()) {
        TabRow(selectedTabIndex = selectedTab) {
            tabs.forEachIndexed { index, title ->
                Tab(
                    selected = selectedTab == index,
                    onClick = { selectedTab = index },
                    text = { Text(title) }
                )
            }
        }
        
        val filteredAppointments = when (selectedTab) {
            0 -> viewModel.getUpcomingAppointments()
            1 -> viewModel.getTodayAppointments()
            2 -> viewModel.getPastAppointments()
            else -> appointments
        }
        
        if (filteredAppointments.isEmpty()) {
            Box(
                modifier = Modifier.fillMaxSize(),
                contentAlignment = Alignment.Center
            ) {
                Text(
                    text = "No appointments found",
                    style = MaterialTheme.typography.bodyLarge,
                    color = MaterialTheme.colorScheme.onSurfaceVariant
                )
            }
        } else {
            val scrollState = rememberScrollState()
            Column(
                modifier = Modifier
                    .fillMaxSize()
                    .verticalScroll(scrollState)
                    .padding(16.dp),
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                filteredAppointments.forEach { appointment ->
                    AppointmentCard(
                        appointment = appointment,
                        onEdit = { onEditAppointment(appointment) },
                        onDelete = { viewModel.deleteAppointment(appointment.id) },
                        onCompleteToggle = { viewModel.markAppointmentComplete(appointment.id, it) },
                        onExport = {
                            exportAppointmentToIcs(viewModel, appointment)
                        }
                    )
                }
            }
        }
    }
}

@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun AppointmentDialog(
    appointment: Appointment?,
    viewModel: AppointmentViewModel,
    onDismiss: () -> Unit,
    onSave: (Appointment) -> Unit
) {
    val now = Clock.System.now().toLocalDateTime(TimeZone.currentSystemDefault())
    
    var title by remember { mutableStateOf(appointment?.title ?: "") }
    var type by remember { mutableStateOf(appointment?.type ?: AppointmentType.KVR) }
    var dateTime by remember { mutableStateOf(appointment?.dateTime ?: LocalDateTime(now.date.plus(1, DateTimeUnit.DAY), now.time)) }
    var location by remember { mutableStateOf(appointment?.location ?: "") }
    
    var street by remember { mutableStateOf(appointment?.address?.street ?: "") }
    var houseNumber by remember { mutableStateOf(appointment?.address?.houseNumber ?: "") }
    var postalCode by remember { mutableStateOf(appointment?.address?.postalCode ?: "") }
    var city by remember { mutableStateOf(appointment?.address?.city ?: "") }
    var district by remember { mutableStateOf(appointment?.address?.district ?: "") }
    
    var notes by remember { mutableStateOf(appointment?.notes ?: "") }
    var reminderMinutes by remember { mutableIntStateOf(appointment?.reminderMinutes ?: 30) }
    var isReminderEnabled by remember { mutableStateOf(appointment?.isReminderEnabled ?: true) }
    
    val requiredDocuments = remember(type) {
        viewModel.getRequiredDocumentsForType(type)
    }
    
    val isEditing = appointment != null
    
    AlertDialog(
        onDismissRequest = onDismiss,
        confirmButton = {
            TextButton(
                onClick = {
                    val newAppointment = Appointment(
                        id = appointment?.id ?: 0,
                        title = title,
                        type = type,
                        dateTime = dateTime,
                        location = location,
                        address = Address(
                            street = street,
                            houseNumber = houseNumber,
                            postalCode = postalCode,
                            city = city,
                            district = district
                        ),
                        notes = notes,
                        reminderMinutes = reminderMinutes,
                        isReminderEnabled = isReminderEnabled,
                        requiredDocuments = requiredDocuments
                    )
                    onSave(newAppointment)
                },
                enabled = title.isNotBlank()
            ) {
                Text(if (isEditing) "Update" else "Save")
            }
        },
        dismissButton = {
            TextButton(onClick = onDismiss) {
                Text("Cancel")
            }
        },
        title = { Text(if (isEditing) "Edit Appointment" else "New Appointment") },
        text = {
            val scrollState = rememberScrollState()
            Column(
                modifier = Modifier
                    .fillMaxWidth()
                    .verticalScroll(scrollState),
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                // Title
                OutlinedTextField(
                    value = title,
                    onValueChange = { title = it },
                    label = { Text("Title") },
                    modifier = Modifier.fillMaxWidth()
                )
                
                // Type selector
                AppointmentTypeSelector(
                    selectedType = type,
                    onTypeSelected = { type = it }
                )
                
                // DateTime picker
                DateTimePicker(
                    selectedDateTime = dateTime,
                    onDateTimeSelected = { dateTime = it }
                )
                
                // Location
                OutlinedTextField(
                    value = location,
                    onValueChange = { location = it },
                    label = { Text("Location Name") },
                    modifier = Modifier.fillMaxWidth()
                )
                
                // Address
                AddressForm(
                    street = street,
                    onStreetChange = { street = it },
                    houseNumber = houseNumber,
                    onHouseNumberChange = { houseNumber = it },
                    postalCode = postalCode,
                    onPostalCodeChange = { postalCode = it },
                    city = city,
                    onCityChange = { city = it },
                    district = district,
                    onDistrictChange = { district = it },
                    onAutoFill = {
                        viewModel.geocodeAddress(street, houseNumber, city, postalCode)
                    }
                )
                
                // Address search results
                val searchResults by viewModel.searchResults.collectAsState()
                if (searchResults.isNotEmpty()) {
                    Card(
                        modifier = Modifier.fillMaxWidth(),
                        colors = CardDefaults.cardColors(
                            containerColor = MaterialTheme.colorScheme.surfaceVariant
                        )
                    ) {
                        Column(modifier = Modifier.padding(8.dp)) {
                            Text(
                                "Select an address:",
                                style = MaterialTheme.typography.labelMedium
                            )
                            searchResults.take(3).forEach { result ->
                                TextButton(
                                    onClick = {
                                        street = result.address.street
                                        houseNumber = result.address.houseNumber
                                        postalCode = result.address.postalCode
                                        city = result.address.city
                                        district = result.address.district
                                        viewModel.clearSearchResults()
                                    }
                                ) {
                                    Text(
                                        result.displayName,
                                        maxLines = 1,
                                        style = MaterialTheme.typography.bodySmall
                                    )
                                }
                            }
                        }
                    }
                }
                
                // Reminder
                ReminderSelector(
                    reminderMinutes = reminderMinutes,
                    isEnabled = isReminderEnabled,
                    onReminderChanged = { minutes, enabled ->
                        reminderMinutes = minutes
                        isReminderEnabled = enabled
                    }
                )
                
                // Notes
                OutlinedTextField(
                    value = notes,
                    onValueChange = { notes = it },
                    label = { Text(Translations.notes()) },
                    modifier = Modifier.fillMaxWidth(),
                    minLines = 2
                )
                
                // Required documents preview
                if (requiredDocuments.isNotEmpty()) {
                    Text(
                        "Required Documents (${requiredDocuments.size} items)",
                        style = MaterialTheme.typography.labelMedium,
                        color = MaterialTheme.colorScheme.primary
                    )
                    requiredDocuments.take(3).forEach { doc ->
                        Row(verticalAlignment = Alignment.CenterVertically) {
                            Checkbox(checked = false, onCheckedChange = {})
                            Text(doc.name, style = MaterialTheme.typography.bodySmall)
                        }
                    }
                }
            }
        }
    )
}

@Composable
fun PersonalInfoScreen(
    personalInfo: PersonalInfo,
    onSave: (PersonalInfo) -> Unit
) {
    var firstName by remember { mutableStateOf(personalInfo.firstName) }
    var lastName by remember { mutableStateOf(personalInfo.lastName) }
    var birthDate by remember { mutableStateOf(personalInfo.birthDate) }
    var email by remember { mutableStateOf(personalInfo.email) }
    var phone by remember { mutableStateOf(personalInfo.phone) }
    
    var street by remember { mutableStateOf(personalInfo.defaultAddress.street) }
    var houseNumber by remember { mutableStateOf(personalInfo.defaultAddress.houseNumber) }
    var postalCode by remember { mutableStateOf(personalInfo.defaultAddress.postalCode) }
    var city by remember { mutableStateOf(personalInfo.defaultAddress.city) }
    var district by remember { mutableStateOf(personalInfo.defaultAddress.district) }
    
    val scrollState = rememberScrollState()
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .verticalScroll(scrollState)
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        Card(modifier = Modifier.fillMaxWidth()) {
            Column(
                modifier = Modifier.padding(16.dp),
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                Text(
                    Translations.personalInfo(),
                    style = MaterialTheme.typography.titleMedium
                )
                
                OutlinedTextField(
                    value = firstName,
                    onValueChange = { firstName = it },
                    label = { Text(Translations.firstName()) },
                    modifier = Modifier.fillMaxWidth()
                )
                
                OutlinedTextField(
                    value = lastName,
                    onValueChange = { lastName = it },
                    label = { Text(Translations.lastName()) },
                    modifier = Modifier.fillMaxWidth()
                )
                
                OutlinedTextField(
                    value = birthDate,
                    onValueChange = { birthDate = it },
                    label = { Text(Translations.birthDate()) },
                    placeholder = { Text("DD.MM.YYYY") },
                    modifier = Modifier.fillMaxWidth()
                )
                
                OutlinedTextField(
                    value = email,
                    onValueChange = { email = it },
                    label = { Text("Email") },
                    modifier = Modifier.fillMaxWidth()
                )
                
                OutlinedTextField(
                    value = phone,
                    onValueChange = { phone = it },
                    label = { Text("Phone") },
                    modifier = Modifier.fillMaxWidth()
                )
            }
        }
        
        AddressForm(
            street = street,
            onStreetChange = { street = it },
            houseNumber = houseNumber,
            onHouseNumberChange = { houseNumber = it },
            postalCode = postalCode,
            onPostalCodeChange = { postalCode = it },
            city = city,
            onCityChange = { city = it },
            district = district,
            onDistrictChange = { district = it }
        )
        
        Button(
            onClick = {
                onSave(
                    PersonalInfo(
                        firstName = firstName,
                        lastName = lastName,
                        birthDate = birthDate,
                        email = email,
                        phone = phone,
                        defaultAddress = Address(
                            street = street,
                            houseNumber = houseNumber,
                            postalCode = postalCode,
                            city = city,
                            district = district
                        ),
                        preferredLanguage = personalInfo.preferredLanguage
                    )
                )
            },
            modifier = Modifier.fillMaxWidth()
        ) {
            Icon(Icons.Default.Save, contentDescription = null)
            Spacer(modifier = Modifier.width(8.dp))
            Text(Translations.save())
        }
    }
}

@Composable
fun SettingsScreen(viewModel: AppointmentViewModel) {
    val scrollState = rememberScrollState()
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .verticalScroll(scrollState)
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        Card(modifier = Modifier.fillMaxWidth()) {
            Column(
                modifier = Modifier.padding(16.dp),
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                Text(
                    "Data Management",
                    style = MaterialTheme.typography.titleMedium
                )
                
                Button(
                    onClick = { exportAllToJson(viewModel) },
                    modifier = Modifier.fillMaxWidth()
                ) {
                    Icon(Icons.Default.FileDownload, contentDescription = null)
                    Spacer(modifier = Modifier.width(8.dp))
                    Text(Translations.exportJSON())
                }
                
                Button(
                    onClick = { importFromJson(viewModel) },
                    modifier = Modifier.fillMaxWidth()
                ) {
                    Icon(Icons.Default.FileUpload, contentDescription = null)
                    Spacer(modifier = Modifier.width(8.dp))
                    Text(Translations.importJSON())
                }
                
                Button(
                    onClick = { exportAllToIcs(viewModel) },
                    modifier = Modifier.fillMaxWidth()
                ) {
                    Icon(Icons.Default.CalendarMonth, contentDescription = null)
                    Spacer(modifier = Modifier.width(8.dp))
                    Text(Translations.exportICS())
                }
            }
        }
        
        Card(modifier = Modifier.fillMaxWidth()) {
            Column(
                modifier = Modifier.padding(16.dp),
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                Text(
                    "About",
                    style = MaterialTheme.typography.titleMedium
                )
                Text("Termin Tracker v1.0.2")
                Text("Appointment management for Germany")
                Text("© 2026 Technic Genius GmbH")
            }
        }
    }
}

private fun exportAppointmentToIcs(viewModel: AppointmentViewModel, appointment: Appointment) {
    val fileChooser = JFileChooser().apply {
        dialogTitle = "Export to ICS"
        fileFilter = FileNameExtensionFilter("iCalendar files (*.ics)", "ics")
        selectedFile = File("appointment_${appointment.id}.ics")
    }
    
    if (fileChooser.showSaveDialog(null) == JFileChooser.APPROVE_OPTION) {
        var file = fileChooser.selectedFile
        if (!file.name.endsWith(".ics")) {
            file = File(file.absolutePath + ".ics")
        }
        viewModel.exportToIcs(file.absolutePath)
    }
}

private fun exportAllToJson(viewModel: AppointmentViewModel) {
    val fileChooser = JFileChooser().apply {
        dialogTitle = "Export to JSON"
        fileFilter = FileNameExtensionFilter("JSON files (*.json)", "json")
        selectedFile = File("termin_tracker_backup.json")
    }
    
    if (fileChooser.showSaveDialog(null) == JFileChooser.APPROVE_OPTION) {
        var file = fileChooser.selectedFile
        if (!file.name.endsWith(".json")) {
            file = File(file.absolutePath + ".json")
        }
        viewModel.exportToJson(file.absolutePath)
    }
}

private fun importFromJson(viewModel: AppointmentViewModel) {
    val fileChooser = JFileChooser().apply {
        dialogTitle = "Import from JSON"
        fileFilter = FileNameExtensionFilter("JSON files (*.json)", "json")
    }
    
    if (fileChooser.showOpenDialog(null) == JFileChooser.APPROVE_OPTION) {
        viewModel.importFromJson(fileChooser.selectedFile.absolutePath)
    }
}

private fun exportAllToIcs(viewModel: AppointmentViewModel) {
    val fileChooser = JFileChooser().apply {
        dialogTitle = "Export Calendar to ICS"
        fileFilter = FileNameExtensionFilter("iCalendar files (*.ics)", "ics")
        selectedFile = File("termin_tracker_calendar.ics")
    }
    
    if (fileChooser.showSaveDialog(null) == JFileChooser.APPROVE_OPTION) {
        var file = fileChooser.selectedFile
        if (!file.name.endsWith(".ics")) {
            file = File(file.absolutePath + ".ics")
        }
        viewModel.exportToIcs(file.absolutePath)
    }
}

enum class Screen {
    Appointments, PersonalInfo, Settings
}

